{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Folkeafstemning",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "Titel",
    "Spørgsmål",
    "Valgdag",
    "Valgart",
    "FrigivelsesTidspunktUTC",
    "OpdateringsTidspunktUTC"
  ],
  "properties": {
    "Valgdag": {
      "type": "string",
      "description": "Dato for valget",
      "format": "date",
      "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4})$"
    },
    "Valgart": {
      "description": "Navn på valget fx.: Folkeafstemning",
      "oneOf": [
        {
          "$ref": "#/definitions/Valgart"
        }
      ]
    },
    "FrigivelsesTidspunktUTC": {
      "type": "string",
      "description": "UTC DateTime for filens oprettelse.",
      "format": "date-time",
      "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4}) (0[0-9]|1[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])$"
    },
    "OpdateringsTidspunktUTC": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4}) (0[0-9]|1[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])$"
    },
    "Titel": {
      "type": "string",
      "description": "Titlen på afstemningsspørgsmålet"
    },
    "Spørgsmål": {
      "type": "string",
      "description": "Afstemningsspørgsmålet"
    }
  },
  "definitions": {
    "Valgart": {
      "type": "string",
      "enum": [
        "Europa-Parlamentsvalg",
        "Folketingsvalg",
        "Regionsrådsvalg",
        "Kommunalvalg",
        "Folkeafstemning"
      ]
    }
  }
}
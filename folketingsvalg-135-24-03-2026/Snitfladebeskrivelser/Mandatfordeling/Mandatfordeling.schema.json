{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Mandatfordeling",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "Valgart",
    "Valgdag",
    "FrigivelsesTidspunktUTC",
    "Resultatart",
    "PersonligeMandater",
    "ListeMandater",
    "Kandidatliste",
    "BaseretPåOptællinger"
  ],
  "properties": {
    "Valgart": {
      "description": "Navn på valget fx.: Folketingsvalg.",
      "oneOf": [
        {
          "$ref": "#/definitions/ExportIndividualElectionDiscriminator"
        }
      ]
    },
    "Valgdag": {
      "type": "string",
      "description": "Dato for valget",
      "format": "date",
      "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4})$"
    },
    "FrigivelsesTidspunktUTC": {
      "type": "string",
      "description": "UTC DateTime for filens oprettelse.",
      "format": "date-time",
      "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4}) (0[0-9]|1[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])$"
    },
    "Kommune": {
      "type": [
        "null",
        "string"
      ],
      "description": "Navn på kommunen"
    },
    "Kommunekode": {
      "type": [
        "integer",
        "null"
      ],
      "description": "Kode på kommunen",
      "format": "int32"
    },
    "Region": {
      "type": [
        "null",
        "string"
      ],
      "description": "Navn på regionen"
    },
    "RegionDagiId": {
      "type": [
        "null",
        "string"
      ],
      "description": "Dagi id for regionen"
    },
    "Resultatart": {
      "type": "string",
      "description": "{Streng af 2 forskellige typer: ['ForeløbigOptælling -  Resultaterne er fra den foreløbige optælling', 'Fintælling - Resultaterne er fra fintælling' ]"
    },
    "PersonligeMandater": {
      "type": "array",
      "description": "Indeholder en liste af Personlige Mandat objekter.",
      "items": {
        "$ref": "#/definitions/PersonligeMandat"
      }
    },
    "ListeMandater": {
      "type": "array",
      "description": "Indeholder en liste af Listemandater objekter.",
      "items": {
        "$ref": "#/definitions/ListeMandat"
      }
    },
    "Kandidatliste": {
      "type": "array",
      "description": "Indeholder en liste af Kandidatliste objekter.",
      "items": {
        "$ref": "#/definitions/Kandidatliste"
      }
    },
    "BaseretPåOptællinger": {
      "type": "array",
      "description": "Indeholder en liste af optællinger, som resultatet er baseret på",
      "items": {
        "$ref": "#/definitions/BaseretPåOptællinger"
      }
    }
  },
  "definitions": {
    "ExportIndividualElectionDiscriminator": {
      "type": "string",
      "description": "",
      "x-enumNames": [
        "EuropeanParliamentElection",
        "GeneralElection",
        "RegionalElection",
        "MunicipalElection",
        "Referendum"
      ],
      "enum": [
        "Europa-Parlamentsvalg",
        "Folketingsvalg",
        "Regionsrådsvalg",
        "Kommunalvalg",
        "Folkeafstemning"
      ]
    },
    "PersonligeMandat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Nummer",
        "NummerAnførtPåListen",
        "KandidatId",
        "Stemmeseddelnavn",
        "KandidatlisteId",
        "KandidatlisteNavn",
        "Bogstavbetegnelse"
      ],
      "properties": {
        "Nummer": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Nummeret på mandatet, eller null hvis ingen mandat blev tildelt kandidaten",
          "format": "int32"
        },
        "NummerAnførtPåListen": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Nummeret for mandatet på kandidatlisten",
          "format": "int32"
        },
        "KandidatId": {
          "type": "string",
          "description": "Id'et på kandidaten",
          "format": "guid"
        },
        "Stemmeseddelnavn": {
          "type": [
            "null",
            "string"
          ],
          "description": "Stemmeseddelnavn på kandidaten"
        },
        "KandidatlisteId": {
          "type": "string",
          "description": "Id'et på kandidatlisten, som kandidaten tilhører",
          "format": "guid"
        },
        "KandidatlisteNavn": {
          "type": "string",
          "description": "Navnet på kandidatlisten, som kandidaten tilhører"
        },
        "Bogstavbetegnelse": {
          "type": "string",
          "description": "Bogstavbetegnelsen på kandidatlisten, som kandidaten tilhører"
        }
      }
    },
    "ListeMandat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "KandidatlisteId",
        "KandidatlisteNavn",
        "Bogstavbetegnelse"
      ],
      "properties": {
        "Nummer": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Nummeret på mandatet, eller null hvis ingen mandat blev tildelt listen",
          "format": "int32"
        },
        "KandidatlisteId": {
          "type": "string",
          "description": "Id'et på kandidatlisten, som kandidaten tilhører",
          "format": "guid"
        },
        "KandidatlisteNavn": {
          "type": [
            "null",
            "string"
          ],
          "description": "Navnet på kandidatlisten, som kandidaten tilhører"
        },
        "Bogstavbetegnelse": {
          "type": [
            "null",
            "string"
          ],
          "description": "Bogstavbetegnelsen på kandidatlisten, som kandidaten tilhører"
        }
      }
    },
    "Kandidatliste": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "KandidatlisteId",
        "KandidatlisteNavn",
        "Bogstavbetegnelse",
        "Stedfortrædere"
      ],
      "properties": {
        "KandidatlisteId": {
          "type": "string",
          "description": "Id'et på kandidatlisten, som kandidaten tilhører",
          "format": "guid"
        },
        "KandidatlisteNavn": {
          "type": "string",
          "description": "Navnet på kandidatlisten, som kandidaten tilhører"
        },
        "Bogstavbetegnelse": {
          "type": "string",
          "description": "Bogstavbetegnelsen på kandidatlisten, som kandidaten tilhører"
        },
        "Stedfortrædere": {
          "type": "array",
          "description": "Indeholder en liste af Stedfortrædere objekter.",
          "items": {
            "$ref": "#/definitions/Stedfortræder"
          }
        }
      }
    },
    "Stedfortræder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Nummer",
        "KandidatId",
        "Stemmeseddelnavn"
      ],
      "properties": {
        "Nummer": {
          "type": "integer",
          "description": "Nummeret på stedfortræderen",
          "format": "int32"
        },
        "KandidatId": {
          "type": "string",
          "description": "Id'et på kandidaten",
          "format": "guid"
        },
        "Stemmeseddelnavn": {
          "type": [
            "null",
            "string"
          ],
          "description": "Stemmeseddelnavn på kandidaten"
        }
      }
    },
    "BaseretPåOptællinger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "AfstemningsområdeDagiId",
        "Resultatart",
        "GodkendelsesDatoUTC"
      ],
      "properties": {
        "AfstemningsområdeDagiId": {
          "type": "integer",
          "description": "Afstemningsområde Id i DAGI",
          "format": "int32"
        },
        "Resultatart": {
          "description": "{Streng af 2 forskellige typer: ['ForeløbigOptælling -  Resultaterne er fra den foreløbige optælling', 'Fintælling - Resultaterne er fra fintælling' ]",
          "oneOf": [
            {
              "$ref": "#/definitions/Resultatart"
            }
          ]
        },
        "GodkendelsesDatoUTC": {
          "type": "string",
          "description": "UTC-tidspunkt for godkendelse af resultaterne",
          "format": "date-time",
          "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4}) (0[0-9]|1[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])$"
        }
      }
    },
    "Resultatart": {
      "type": "string",
      "enum": [
        "ForeløbigOptælling",
        "Fintælling"
      ]
    }
  }
}
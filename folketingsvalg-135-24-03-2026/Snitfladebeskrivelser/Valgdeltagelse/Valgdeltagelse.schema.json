{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Valgdeltagelse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "Valgart",
    "Valgdag",
    "FrigivelsesTidspunktUTC",
    "Kommune",
    "Kommunekode",
    "Afstemningsområde",
    "AfstemningsområdeDagiId",
    "AfstemningsområdeNummer",
    "Valgdeltagelse"
  ],
  "properties": {
    "Valgart": {
      "type": "string",
      "description": "Navn på valget fx.: Folketingsvalg."
    },
    "Valgdag": {
      "type": "string",
      "description": "Dato for valget",
      "format": "date",
      "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4})$"
    },
    "FrigivelsesTidspunktUTC": {
      "type": "string",
      "description": "UTC DateTime for filens oprettelse.",
      "format": "date-time",
      "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4}) (0[0-9]|1[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])$"
    },
    "Kommune": {
      "type": "string",
      "description": "Navn på kommunen"
    },
    "Kommunekode": {
      "type": "integer",
      "description": "Kode på kommunen",
      "format": "int32"
    },
    "Afstemningsområde": {
      "type": "string",
      "description": "Navn på afstemningsområde"
    },
    "AfstemningsområdeDagiId": {
      "type": "string",
      "description": "Afstemningsområde Id i DAGI"
    },
    "AfstemningsområdeNummer": {
      "type": "integer",
      "description": "Nummeret på afstemningsområdet",
      "format": "int32"
    },
    "Valgdeltagelse": {
      "type": "array",
      "description": "Indeholder en liste af Valgdeltagelse objekter.",
      "items": {
        "$ref": "#/definitions/Valgdeltagelse"
      }
    }
  },
  "definitions": {
    "Valgdeltagelse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "AntalStemmeberretigedeVælgere",
        "AfgivneStemmer",
        "Tidspunkt"
      ],
      "properties": {
        "AntalStemmeberretigedeVælgere": {
          "type": "integer",
          "description": "Antallet på stemmeberettigede vælgere",
          "format": "int32"
        },
        "AfgivneStemmer": {
          "type": "integer",
          "description": "Antallet af afgivne stemmer",
          "format": "int32"
        },
        "Tidspunkt": {
          "type": "string",
          "description": "Tidspunktet for hvornår denne valgdeltagelse blev registreret på formatet: tt:mm.",
          "format": "time"
        }
      }
    }
  }
}
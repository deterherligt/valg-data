{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Storkreds",
  "type": "array",
  "items": {
    "$ref": "#/definitions/Storkreds"
  },
  "definitions": {
    "Storkreds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "OprettetUtc",
        "OpdateretUtc",
        "Nummer",
        "Navn",
        "Valglandsdelkode",
        "Type"
      ],
      "properties": {
        "OprettetUtc": {
          "type": "string",
          "description": "Tidspunktet entiteten blev oprettet i Valg-systemet. Præsenteret i UTC.",
          "format": "date-time",
          "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4}) (0[0-9]|1[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])$"
        },
        "OpdateretUtc": {
          "type": [
            "null",
            "string"
          ],
          "description": "Tidspunktet entiteten blev opdateret i Valg-systemet. Præsenteret i UTC.",
          "format": "date-time",
          "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4}) (0[0-9]|1[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])$"
        },
        "Nummer": {
          "type": "integer",
          "description": "Storkredsnummer for en given storkreds",
          "format": "int32"
        },
        "Navn": {
          "type": "string",
          "description": "Navn på storkreds"
        },
        "Valglandsdelkode": {
          "type": "string",
          "description": "Kode på landsdel"
        },
        "Type": {
          "description": "Valggeografi objekt type",
          "oneOf": [
            {
              "$ref": "#/definitions/Type"
            }
          ]
        }
      }
    },
    "Type": {
      "type": "string",
      "enum": [
        "Afstemningsområde",
        "Region",
        "Kommune",
        "Landsdel",
        "Opstillingskreds",
        "Storkreds"
      ]
    }
  }
}
{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Afstemningsomraade",
  "type": "array",
  "items": {
    "$ref": "#/definitions/Afstemningsomraade"
  },
  "definitions": {
    "Afstemningsomraade": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "OprettetUtc",
        "OpdateretUtc",
        "Dagi_id",
        "Nummer",
        "Navn",
        "Afstemningssted",
        "Kommunekode",
        "Opstillingskredsnummer",
        "Opstillingskreds_Dagi_id",
        "Type"
      ],
      "properties": {
        "OprettetUtc": {
          "type": "string",
          "description": "Tidspunktet entiteten blev oprettet i Valg-systemet. Prćsenteret i UTC.",
          "format": "date-time",
          "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4}) (0[0-9]|1[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])$"
        },
        "OpdateretUtc": {
          "type": [
            "null",
            "string"
          ],
          "description": "Tidspunktet entiteten blev opdateret i Valg-systemet. Prćsenteret i UTC.",
          "format": "date-time",
          "pattern": "^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(\\d{4}) (0[0-9]|1[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])$"
        },
        "Dagi_id": {
          "type": "string",
          "description": "Afstemningsomrĺde Id i DAGI"
        },
        "Nummer": {
          "type": "integer",
          "description": "Afstemningsomrĺdenummer",
          "format": "int32"
        },
        "Navn": {
          "type": "string",
          "description": "Navn pĺ valgomrĺde"
        },
        "Afstemningssted": {
          "$ref": "#/definitions/Afstemningssted"
        },
        "Kommunekode": {
          "type": "integer",
          "description": "Koden pĺ kommunen",
          "format": "int32"
        },
        "Opstillingskredsnummer": {
          "type": "integer",
          "description": "Opstillingskredsnummer - Unikt blandt alle opstillingskredse",
          "format": "int32"
        },
        "Opstillingskreds_Dagi_id": {
          "type": "string",
          "description": "Opstillingskreds Id i DAGI"
        },
        "Type": {
          "description": "Valggeografi objekt type",
          "oneOf": [
            {
              "$ref": "#/definitions/Type"
            }
          ]
        }
      }
    },
    "Afstemningssted": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Navn",
        "Adgangsadresse"
      ],
      "properties": {
        "Navn": {
          "type": "string",
          "description": "Navn pĺ stemmestedet"
        },
        "Adgangsadresse": {
          "$ref": "#/definitions/Adgangsadresse"
        }
      }
    },
    "Adgangsadresse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Id",
        "Adressebetegnelse"
      ],
      "properties": {
        "Id": {
          "type": [
            "null",
            "string"
          ],
          "description": "Guid-identifikator af stemmestedets adresse (DAR ID)",
          "format": "guid"
        },
        "Adressebetegnelse": {
          "type": "string",
          "description": "Adresse pĺ stemmestedet"
        }
      }
    },
    "Type": {
      "type": "string",
      "enum": [
        "Afstemningsomrĺde",
        "Region",
        "Kommune",
        "Landsdel",
        "Opstillingskreds",
        "Storkreds"
      ]
    }
  }
}